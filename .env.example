# ---- PostgreSQL ----
POSTGRES_USER=raguser
POSTGRES_PASSWORD=ragpassword
POSTGRES_DB=ai_rag_platform
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_PORT=6379

# ---- MinIO ----
MINIO_ROOT_USER=ragadmin
MINIO_ROOT_PASSWORD=ragadminpassword
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=documents

# ---- Qdrant ----
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# ---- Ollama ----
OLLAMA_PORT=11434
OLLAMA_MODEL=llama3.2

# ---- Auth ----
JWT_SECRET=change-me-in-production
JWT_EXPIRY_HOURS=24

# ---- Service ports (host-exposed) ----
API_GATEWAY_PORT=8080
AUTH_SERVICE_PORT=8081
DOCUMENT_SERVICE_PORT=8082
OCR_SERVICE_PORT=8083
EMBEDDING_SERVICE_PORT=8084
RAG_SERVICE_PORT=8085
NOTIFICATION_SERVICE_PORT=8086
